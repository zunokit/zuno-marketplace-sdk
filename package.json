{
  "name": "zuno-marketplace-sdk",
  "version": "2.2.0-beta.7",
  "description": "All-in-One NFT Marketplace SDK with Wagmi & React Query built-in",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./exchange": {
      "types": "./dist/exchange/index.d.ts",
      "import": "./dist/exchange/index.mjs",
      "require": "./dist/exchange/index.js"
    },
    "./auction": {
      "types": "./dist/auction/index.d.ts",
      "import": "./dist/auction/index.mjs",
      "require": "./dist/auction/index.js"
    },
    "./collection": {
      "types": "./dist/collection/index.d.ts",
      "import": "./dist/collection/index.mjs",
      "require": "./dist/collection/index.js"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "import": "./dist/logger/index.mjs",
      "require": "./dist/logger/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.mjs",
      "require": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "examples/**/*"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "jest --config tests/setup/jest.config.js",
    "test:watch": "jest --config tests/setup/jest.config.js --watch",
    "test:coverage": "jest --config tests/setup/jest.config.js --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "keywords": [
    "nft",
    "marketplace",
    "web3",
    "ethereum",
    "wagmi",
    "react-query",
    "sdk",
    "blockchain",
    "smart-contracts"
  ],
  "author": "Zuno Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZunoKit/zuno-marketplace-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/ZunoKit/zuno-marketplace-sdk/issues"
  },
  "homepage": "https://github.com/ZunoKit/zuno-marketplace-sdk#readme",
  "dependencies": {
    "@tanstack/query-core": "^5.94.5",
    "@tanstack/react-query": "^5.94.5",
    "@types/jest": "^30.0.0",
    "@wagmi/connectors": "^5.11.2",
    "@wagmi/core": "^2.22.1",
    "ethers": "^6.16.0",
    "ms": "^2.1.3",
    "viem": "^2.47.6",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
